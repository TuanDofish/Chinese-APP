@startuml
start
:Người học nhập câu tiếng Trung;

if (Câu rỗng?) then (Có)
  :Yêu cầu nhập lại;
  stop
else (Không)
  :Gửi yêu cầu kiểm tra tới AI;

  if (AI phản hồi thành công?) then (Có)
    :Phân tích JSON kết quả;
    :Hiển thị điểm số;
    :Hiển thị lỗi và giải thích;
    :Hiển thị câu sửa và gợi ý;
  else (Không)
    :Hiển thị lỗi kết nối hoặc fallback mock;
  endif
endif

stop
@enduml
